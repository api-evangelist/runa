{
  "@context": {
    "@version": 1.1,
    "runa": "https://developer.runa.io/vocab/",
    "schema": "https://schema.org/",

    "Order": "schema:Order",
    "Product": "schema:Product",
    "Balance": "runa:Balance",
    "OrderItem": "schema:OrderItem",

    "id": "@id",
    "name": {
      "@id": "schema:name",
      "@type": "schema:Text"
    },
    "description": {
      "@id": "schema:description",
      "@type": "schema:Text"
    },
    "status": {
      "@id": "runa:orderStatus",
      "@type": "schema:Text"
    },
    "created_at": {
      "@id": "schema:dateCreated",
      "@type": "schema:DateTime"
    },
    "completed_at": {
      "@id": "schema:dateModified",
      "@type": "schema:DateTime"
    },
    "face_value": {
      "@id": "schema:price",
      "@type": "schema:Number"
    },
    "currency": {
      "@id": "schema:priceCurrency",
      "@type": "schema:Text"
    },
    "balance": {
      "@id": "runa:accountBalance",
      "@type": "schema:Text"
    },
    "categories": {
      "@id": "schema:category",
      "@container": "@list"
    },
    "countries": {
      "@id": "schema:areaServed",
      "@container": "@list"
    },
    "image_url": {
      "@id": "schema:image",
      "@type": "@id"
    },
    "payout": {
      "@id": "runa:payout"
    },
    "url": {
      "@id": "schema:url",
      "@type": "@id"
    },
    "expires_at": {
      "@id": "schema:expires",
      "@type": "schema:DateTime"
    }
  }
}
